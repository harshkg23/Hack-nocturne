{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "strict": true,
        "outDir": "./dist",
        "rootDir": ".",
        "skipLibCheck": true,
        "moduleResolution": "node"
    },
    "include": [
        "scripts/**/*.ts"
    ]
}