# Default provider for Architect node: openai | anthropic
LLM_PROVIDER=openai

# OpenAI (recommended if you already have this key)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_REAL_ONLY=false

# Optional Anthropic support
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Phase 2: backend execution settings
RUN_TESTS_MODE=api
SENTINEL_BACKEND_URL=http://localhost:3000
TARGET_URL=http://localhost:3000
RUN_TESTS_TIMEOUT_SECONDS=60

# RAG Memory (MongoDB Atlas Vector Search)
# Requires: Atlas cluster with a vector search index named "healer_vector_index"
# on collection: sentinelqa.healer_memory, path: embedding, dimensions: 1536, similarity: cosine
# MONGODB_URI is reused from above — no new env var needed
MONGODB_URI=
